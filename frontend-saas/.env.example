# API Base URL - en dev dejar vacío/comentado para usar proxy Vite (evita CORS).
# En producción descomenta y apunta a tu backend:
# VITE_API_BASE_URL=https://tu-dominio.com/api

# URL del Punto de Venta (Flask PosAgil). En local con Docker del POS suele ser:
#   VITE_POSAGIL_PUBLIC_URL=http://localhost:5001/
# Flask en el host (sin Docker) suele usar el puerto 5000:
#   VITE_POSAGIL_DEV_PORT=5000
# Con gateway Nginx unificado (mismo dominio /pos/):
#   VITE_POSAGIL_PUBLIC_URL=http://localhost:8080/pos/
# Si no defines esta variable, en `npm run dev` se intentará abrir automáticamente el mismo host en el puerto 5001.
# VITE_POSAGIL_PUBLIC_URL=http://localhost:5001/
