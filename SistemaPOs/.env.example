AZ_SECRET_KEY=change-me-long-random
AZ_DEBUG=0
AZ_HOST=127.0.0.1
# Desarrollo local; en PaaS suele usarse PORT (p. ej. DigitalOcean inyecta PORT).
AZ_PORT=5000

# URL pública HTTPS del servidor (sin barra final). Obligatoria en producción para enlaces
# (WhatsApp, emails) y para que las plantillas no dependan de 127.0.0.1.
# PUBLIC_BASE_URL=https://factura.suempresa.com
# AZ_PUBLIC_BASE_URL es alias de PUBLIC_BASE_URL.

# Detrás de proxy HTTPS (nginx, DigitalOcean App Platform): descomentar en producción.
# AZ_TRUST_PROXY=1
# AZ_PREFERRED_URL_SCHEME=https

# --- Base de datos ---
# En servidor (DigitalOcean Postgres, etc.) use la cadena que da el panel, no 127.0.0.1:
# DATABASE_URL=postgresql://user:pass@host-regional.db.ondigitalocean.com:25060/defaultdb?sslmode=require
# Si no usa DATABASE_URL, use variables sueltas (solo desarrollo local típico):
AZ_DB_NAME=saas_facturacion
AZ_DB_USER=postgres
AZ_DB_PASSWORD=your-password
# Solo Flask/Python en el MISMO equipo que PostgreSQL (sin Docker):
AZ_DB_HOST=127.0.0.1
AZ_DB_PORT=5432
#
# --- Docker Compose (SistemaPOs/docker-compose.yml) ---
# - Servicio `db` (Postgres 16) usa estos mismos AZ_DB_* para crear la base inicial.
# - PosAgil conecta a host `db` por defecto (misma red). Para Postgres en Windows: POSAGIL_DB_HOST=host.docker.internal
# - Puerto en el host: 5433→5432 (variable POSAGIL_PG_HOST_PORT) para no chocar con Postgres nativo.
# Levantar: docker compose up -d --build
# Verificar multi-empresa: python scripts/verificar_multiempresa.py
# Si falta el esquema (error "relation usuarios does not exist"): python scripts/bootstrap_bd.py
# Los usuarios del POS pueden crearse solos vía SSO desde AgilDTE (mismo username que Django).

# --- Backend central AgilDTE (Django REST, prefijo /api/) — POS opcional ---
# URL sin barra final. También acepta VITE_AGILDTE_BASE_URL si reutiliza el mismo .env que el front.
# Docker (PosAgil en compose + backend en compose raíz, ambos en red agildte_net): usar nombre del servicio API:
# AGILDTE_DOCKER_API_URL=http://backend:8000
# Si Django corre en Windows/Mac fuera de Docker pero expone el puerto al host:
# AGILDTE_DOCKER_API_URL=http://host.docker.internal:8000
# Local típico (Django runserver):
# AGILDTE_BASE_URL=http://127.0.0.1:8000
# AGILDTE_BASE_URL=https://api.midominio.com
# Usuario restringido a una sola empresa (no superusuario). Sin esto fallan sync y «Sincronizar con Hacienda»:
AGILDTE_USERNAME=tu_usuario_django
AGILDTE_PASSWORD=tu_clave
# Forzar tenant si el login devuelve varias empresas (opcional):
# AGILDTE_EMPRESA_ID=1
# Tras guardar venta local, POST crear-con-detalles en AgilDTE (ya dispara DTE/MH allí):
# AGILDTE_SYNC_ENABLED=0
# Para desarrollo puede poner AGILDTE_SYNC_ENABLED=1 (requiere URL + credenciales válidas).
# Opcional: tras sync exitoso, GET generar-dte para JSON diagnóstico (suele ser antes de que MH firme):
# AGILDTE_FETCH_DTE_JSON=0
# Segundos de espera al guardar venta hacia /api/pos/procesar-venta/ (AgilDTE + MH en modo síncrono)
# AGILDTE_POS_VENTA_TIMEOUT=180

# --- SSO PosAgil ↔ AgilDTE (login único) ---
# URL del portal (SPA). Vite en dev suele ser :3000; si todo pasa por nginx gateway, :8080.
# AGILDTE_PORTAL_LOGIN_URL=http://localhost:3000/login
# AZ_AGILDTE_PORTAL_LOGIN_URL es alias.
# Solo emergencia / desarrollo: permitir usuario+clave en /login del POS.
# POSAGIL_ALLOW_LOCAL_LOGIN=0
