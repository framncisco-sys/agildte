# ─────────────────────────────────────────────────────────────────────────────
# AgilDTE — Variables de entorno para PRODUCCIÓN
# Copia este archivo a .env y ajusta cada valor. Sin espacios al lado del =
# ─────────────────────────────────────────────────────────────────────────────

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
POSTGRES_DB=sistema_contable
POSTGRES_USER=sistema_user
POSTGRES_PASSWORD=contraseña_segura_aqui

# ─── DJANGO ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=genera_uno_con_python_-c_"import_secrets;print(secrets.token_hex(50))"
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Orígenes permitidos para el frontend (separados por coma, sin espacios)
CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ─── DOMINIO (nginx / certbot) ────────────────────────────────────────────────
# Nginx sustituye ${DOMAIN} en nginx.conf. Certbot lo usa para pedir el cert.
DOMAIN=tudominio.com

# ─── BACKUP (retención legal 5 años para facturas) ─────────────────────────────
# Diarios: 90 días (recuperación rápida)
BACKUP_KEEP_DAYS=90
# Mensuales: 5 años (1825 días) — obligatorio por ley tributaria SV
BACKUP_MONTHLY_KEEP_DAYS=1825

# ─── FIRMA DTE ────────────────────────────────────────────────────────────────
# true = firmador interno Python (recomendado, no requiere contenedor extra)
USE_INTERNAL_FIRMADOR=true
# false = contenedor firmador externo
# USE_INTERNAL_FIRMADOR=false
# FIRMADOR_URL=http://firmador:8113/
# FIRMADOR_IMAGE=nombre_de_tu_imagen_firmador

# ─── FACTURACIÓN: síncrona por defecto (transmisión inmediata a MH, estado RECIBIDO al instante) ─
# USE_ASYNC_FACTURACION=true   # true = cola en segundo plano; false = esperar respuesta MH
USE_ASYNC_FACTURACION=false
# PosAgil (POST /api/pos/procesar-venta/): true = siempre MH en la misma petición (sello en ticket); false = seguir USE_ASYNC_FACTURACION
POSAGIL_FACTURACION_SINCRONA=true

# ─── MH (Ministerio de Hacienda) ─────────────────────────────────────────────
# Solo descomentar para debug de credenciales. Eliminar en producción estable.
# MH_PASSWORD_OVERRIDE=contraseña_temporal

# ─── CORREO (Amazon SES) ──────────────────────────────────────────────────────
# Opción A — SES API (HTTPS, puerto 443): cuando SMTP 587/465 está bloqueado.
# Crea un Access Key en IAM con política ses:SendRawEmail.
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_REGION=us-east-1
EMAIL_FROM_ADDRESS=AgilDTE <facturas@tudominio.com>

# Opción B — SMTP (puertos 587/465): credenciales SMTP de SES desde IAM → Create SMTP credentials
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=AKIA...
# EMAIL_HOST_PASSWORD=...
# EMAIL_FROM_ADDRESS=AgilDTE <facturas@tudominio.com>
